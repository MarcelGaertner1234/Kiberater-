// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  user
  advisor
  admin
}

enum CompanySize {
  freelancer
  startup
  small
  medium
  large
}

enum AssessmentType {
  quick
  detailed
}

enum MaturityLevel {
  beginner
  intermediate
  advanced
}

enum RoadmapStatus {
  draft
  active
  completed
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
}

enum Priority {
  low
  medium
  high
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum SubscriptionPlan {
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  cancelled
  past_due
}

enum AdvisorAssignmentStatus {
  active
  paused
  ended
}

// Models
model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  name                 String
  passwordHash         String?   @map("password_hash")
  companyName          String?   @map("company_name")
  companySize          CompanySize?
  industry             String?
  role                 UserRole  @default(user)
  avatarUrl            String?   @map("avatar_url")
  locale               String    @default("de")
  timezone             String    @default("Europe/Berlin")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")
  lastLoginAt          DateTime? @map("last_login_at")
  emailVerified        Boolean   @default(false) @map("email_verified")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")

  // Relations
  authProviders        AuthProvider[]
  assessments          Assessment[]
  roadmaps             Roadmap[]
  projects             Project[]
  sentMessages         Message[] @relation("SentMessages")
  receivedMessages     Message[] @relation("ReceivedMessages")
  subscription         Subscription?
  advisorAssignments   AdvisorAssignment[] @relation("UserAssignments")
  advisingAssignments  AdvisorAssignment[] @relation("AdvisorAssignments")
  activityLogs         ActivityLog[]
  assignedTasks        Task[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model AuthProvider {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  provider        String   // google, github, apple, email
  providerUserId  String   @map("provider_user_id")
  accessToken     String?  @map("access_token") @db.Text
  refreshToken    String?  @map("refresh_token") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_providers")
}

model Assessment {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  type            AssessmentType @default(quick)
  responses       Json           // Flexible JSONB for questions/answers
  score           Int?           // 0-100
  maturityLevel   MaturityLevel? @map("maturity_level")
  recommendations Json?          // Generated recommendations
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmaps        Roadmap[]

  @@index([userId])
  @@map("assessments")
}

model Roadmap {
  id                     String        @id @default(uuid())
  userId                 String        @map("user_id")
  assessmentId           String?       @map("assessment_id")
  title                  String
  description            String?       @db.Text
  milestones             Json?         // Array of milestones
  estimatedDurationWeeks Int?          @map("estimated_duration_weeks")
  status                 RoadmapStatus @default(active)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  // Relations
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment             Assessment?   @relation(fields: [assessmentId], references: [id])
  projects               Project[]

  @@map("roadmaps")
}

model Project {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  roadmapId    String?       @map("roadmap_id")
  title        String
  description  String?       @db.Text
  status       ProjectStatus @default(planning)
  priority     Priority      @default(medium)
  startDate    DateTime?     @map("start_date") @db.Date
  dueDate      DateTime?     @map("due_date") @db.Date
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap      Roadmap?      @relation(fields: [roadmapId], references: [id])
  tasks        Task[]
  messages     Message[]

  @@index([userId])
  @@index([status])
  @@map("projects")
}

model Task {
  id           String     @id @default(uuid())
  projectId    String     @map("project_id")
  title        String
  description  String?    @db.Text
  status       TaskStatus @default(todo)
  position     Int        // For Kanban sorting
  assigneeId   String?    @map("assignee_id")
  dueDate      DateTime?  @map("due_date") @db.Date
  completedAt  DateTime?  @map("completed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?      @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

model Message {
  id          String    @id @default(uuid())
  senderId    String    @map("sender_id")
  recipientId String    @map("recipient_id")
  projectId   String?   @map("project_id")
  content     String    @db.Text
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])

  @@index([recipientId])
  @@index([isRead])
  @@map("messages")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(trialing)
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime?          @map("trial_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model AdvisorAssignment {
  id         String                  @id @default(uuid())
  userId     String                  @map("user_id")
  advisorId  String                  @map("advisor_id")
  status     AdvisorAssignmentStatus @default(active)
  notes      String?                 @db.Text
  assignedAt DateTime                @default(now()) @map("assigned_at")
  endedAt    DateTime?               @map("ended_at")

  // Relations
  user       User                    @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  advisor    User                    @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([advisorId])
  @@map("advisor_assignments")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String   // 'assessment_completed', 'project_created', etc.
  entityType String?  @map("entity_type") // 'project', 'task', etc.
  entityId   String?  @map("entity_id")
  metadata   Json?    // Additional context information
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@map("activity_log")
}