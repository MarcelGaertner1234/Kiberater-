// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Models
model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  passwordHash         String?   @map("password_hash")
  companyName          String?   @map("company_name")
  companySize          String?   // freelancer, startup, small, medium, large
  industry             String?
  role                 String    @default("user") // user, advisor, admin
  avatarUrl            String?   @map("avatar_url")
  locale               String    @default("de")
  timezone             String    @default("Europe/Berlin")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")
  lastLoginAt          DateTime? @map("last_login_at")
  emailVerified        Boolean   @default(false) @map("email_verified")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")

  // Relations
  authProviders        AuthProvider[]
  assessments          Assessment[]
  roadmaps             Roadmap[]
  projects             Project[]
  sentMessages         Message[] @relation("SentMessages")
  receivedMessages     Message[] @relation("ReceivedMessages")
  subscription         Subscription?
  advisorAssignments   AdvisorAssignment[] @relation("UserAssignments")
  advisingAssignments  AdvisorAssignment[] @relation("AdvisorAssignments")
  activityLogs         ActivityLog[]
  assignedTasks        Task[]

  @@map("users")
}

model AuthProvider {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  provider        String   // google, github, apple, email
  providerUserId  String   @map("provider_user_id")
  accessToken     String?  @map("access_token")
  refreshToken    String?  @map("refresh_token")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_providers")
}

model Assessment {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  type            String    @default("quick") // quick, detailed
  responses       String    // JSON string for SQLite
  score           Int?      // 0-100
  maturityLevel   String?   @map("maturity_level") // beginner, intermediate, advanced
  recommendations String?   // JSON string for SQLite
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmaps        Roadmap[]

  @@map("assessments")
}

model Roadmap {
  id                     String    @id @default(cuid())
  userId                 String    @map("user_id")
  assessmentId           String?   @map("assessment_id")
  title                  String
  description            String?
  milestones             String?   // JSON string for SQLite
  estimatedDurationWeeks Int?      @map("estimated_duration_weeks")
  status                 String    @default("active") // draft, active, completed
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // Relations
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment             Assessment? @relation(fields: [assessmentId], references: [id])
  projects               Project[]

  @@map("roadmaps")
}

model Project {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  roadmapId    String?   @map("roadmap_id")
  title        String
  description  String?
  status       String    @default("planning") // planning, active, on_hold, completed
  priority     String    @default("medium")   // low, medium, high
  startDate    String?   @map("start_date")   // Date as string in SQLite
  dueDate      String?   @map("due_date")     // Date as string in SQLite
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap      Roadmap?  @relation(fields: [roadmapId], references: [id])
  tasks        Task[]
  messages     Message[]

  @@map("projects")
}

model Task {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  title        String
  description  String?
  status       String    @default("todo") // todo, in_progress, done
  position     Int       // For Kanban sorting
  assigneeId   String?   @map("assignee_id")
  dueDate      String?   @map("due_date")    // Date as string in SQLite
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?     @relation(fields: [assigneeId], references: [id])

  @@map("tasks")
}

model Message {
  id          String    @id @default(cuid())
  senderId    String    @map("sender_id")
  recipientId String    @map("recipient_id")
  projectId   String?   @map("project_id")
  content     String
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])

  @@map("messages")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  plan                 String    // starter, professional, enterprise
  status               String    @default("trialing") // trialing, active, cancelled, past_due
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime? @map("trial_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model AdvisorAssignment {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  advisorId  String    @map("advisor_id")
  status     String    @default("active") // active, paused, ended
  notes      String?
  assignedAt DateTime  @default(now()) @map("assigned_at")
  endedAt    DateTime? @map("ended_at")

  // Relations
  user       User      @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  advisor    User      @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@map("advisor_assignments")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String   // 'assessment_completed', 'project_created', etc.
  entityType String?  @map("entity_type") // 'project', 'task', etc.
  entityId   String?  @map("entity_id")
  metadata   String?  // JSON string for SQLite
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_log")
}