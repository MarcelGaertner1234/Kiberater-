# Server
NODE_ENV=development
PORT=3001

# Database - Supabase PostgreSQL
# Connection Pooling für Anwendung (Port 6543)
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct Connection für Migrations (Port 5432)
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Supabase API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # Service Role Key für Backend-Operationen
SUPABASE_JWT_SECRET=your-supabase-jwt-secret # Aus Project Settings → API

# JWT (kann Supabase JWT Secret verwenden)
JWT_SECRET=${SUPABASE_JWT_SECRET}
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Redis
REDIS_URL=redis://localhost:6379

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@ki-beratung.de

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=eu-central-1
AWS_S3_BUCKET=ki-beratung-uploads

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Frontend URL
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# n8n Webhook Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_API_KEY=your-webhook-api-key