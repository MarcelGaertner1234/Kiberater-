# SUPABASE PostgreSQL Configuration
# Copy this to .env and fill in your actual credentials

# Database URLs - Get from Supabase Dashboard
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Server Configuration
PORT=4000
NODE_ENV=development

# Auth - Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secure-secret-here"
JWT_EXPIRES_IN="7d"

# Supabase Service Role Key - Get from API Settings
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Setup Instructions:
# 1. Go to https://supabase.com/dashboard
# 2. Create new project or use existing
# 3. Go to Settings > Database > Connection
# 4. Copy the connection strings and replace placeholders
# 5. Go to Settings > API and copy service_role key

# Bcrypt
BCRYPT_ROUNDS=10

# Redis
REDIS_URL=redis://localhost:6379

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@ki-beratung.de

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=eu-central-1
AWS_S3_BUCKET=ki-beratung-uploads

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100