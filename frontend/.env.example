# SUPABASE Frontend Configuration
# Copy this to .env.local and fill in your actual credentials

# Database (optional for frontend, mainly for NextAuth.js)
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# NextAuth.js - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Public Configuration - Safe for client-side
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key-here"

# Setup Instructions:
# 1. Go to https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# 2. Copy the Project URL for NEXT_PUBLIC_SUPABASE_URL
# 3. Copy the anon/public key for NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Copy database credentials from Database settings