# Supabase Local Development Environment Variables
# Copy this to .env.supabase and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=your-super-secret-password

# JWT
JWT_SECRET=your-super-secret-jwt-token
JWT_EXPIRY=3600

# Site Configuration
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# Email Configuration
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_SENDER_NAME=KI-Beratungsplattform

# OAuth Providers (Optional)
ENABLE_GOOGLE_SIGNUP=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ENABLE_GITHUB_SIGNUP=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MinIO (S3-compatible storage for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Service Keys (for local development)
