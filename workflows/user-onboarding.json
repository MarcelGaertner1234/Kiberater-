    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "text": "=Erstelle eine personalisierte Willkommensnachricht für einen neuen Nutzer unserer KI-Beratungsplattform.\n\nNutzer-Informationen:\n- Name: {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"name\"]}}\n- Firma: {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"company_name\"]}}\n- Firmengröße: {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"company_size\"]}}\n- Sprache: {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"locale\"] === 'de' ? 'Deutsch' : 'English'}}\n\nDie Nachricht sollte:\n1. Persönlich und professionell sein\n2. Die nächsten Schritte erklären (Assessment durchführen)\n3. Den Wert unserer KI-Beratung hervorheben\n4. Maximal 150 Wörter lang sein\n5. In der Sprache des Nutzers verfasst sein",
        "options": {
          "temperature": 0.7,
          "maxTokens": 300
        }
      },
      "id": "a506095c-1508-419d-98be-531de46c4465",
      "name": "Generate_Welcome_Content_OpenAI",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.3,
      "position": [1120, 32],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000,
      "credentials": {
        "openAiApi": {
          "id": "openai-api",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "operation": "send",
        "toEmail": "={{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"email\"]}}",
        "subject": "={{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"locale\"] === 'de' ? 'Willkommen bei der KI-Beratungsplattform!' : 'Welcome to AI Consulting Platform!'}}",
        "fromEmail": "={{$credentials.fromEmail}}",
        "fromName": "KI-Beratungsplattform",
        "html": "=<html>\n<body style=\"font-family: Arial, sans-serif; line-height: 1.6; color: #333;\">\n  <div style=\"max-width: 600px; margin: 0 auto; padding: 20px;\">\n    <h2 style=\"color: #2563eb;\">{{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"locale\"] === 'de' ? 'Willkommen' : 'Welcome'}}, {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"name\"]}}!</h2>\n    \n    <div style=\"margin: 20px 0;\">\n      {{$node[\"Generate_Welcome_Content_OpenAI\"].json[\"message\"].content}}\n    </div>\n    \n    <div style=\"margin: 30px 0;\">\n      <a href=\"https://ki-beratung.de/assessment\" style=\"background-color: #2563eb; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; display: inline-block;\">\n        {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"locale\"] === 'de' ? 'Assessment starten' : 'Start Assessment'}}\n      </a>\n    </div>\n    \n    <hr style=\"border: none; border-top: 1px solid #e5e7eb; margin: 30px 0;\">\n    \n    <p style=\"font-size: 14px; color: #6b7280;\">\n      {{$node[\"Fetch_User_Data_PostgreSQL\"].json[\"locale\"] === 'de' ? 'Bei Fragen sind wir gerne für Sie da.' : 'If you have any questions, we\\'re here to help.'}}\n    </p>\n  </div>\n</body>\n</html>",
        "options": {
          "sandboxMode": false
        }
      },
