{
  "name": "ki-beratung-platform",
  "version": "1.0.0",
  "description": "KI-Unternehmensberatungs-Plattform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:migrate": "npm run migrate --workspace=backend",
    "db:seed": "npm run seed --workspace=backend",
    "setup": "npm install && npm run db:migrate && npm run db:seed",
    "setup:supabase": "node setup-supabase.js",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install",
    "check:duplicates": "node scripts/check-duplicates.js",
    "check:docs": "node scripts/check-docs.js",
    "test:staged": "jest --bail --findRelatedTests",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ki-beratung-platform.git"
  },
  "keywords": [
    "AI",
    "consulting",
    "platform",
    "nextjs",
    "nodejs",
    "typescript"
  ],
  "author": "Marcel Gaertner",
  "license": "MIT"
}